# =============================================================================
# treevvo-lambda — variáveis de ambiente
# Copie para ".env" na raiz do projeto (local). Em Lambda, defina as mesmas
# chaves no console da função, no SAM template ou no Secrets Manager + referência.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI (obrigatório para gerar roteiro) — local e Lambda
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# SQS — produtor (outro serviço) publica aqui; Lambda e o script local consomem
# -----------------------------------------------------------------------------
# URL completa da fila. Na Lambda, prefira definir (evita depender do default no código).
SQS_GENERATE_TRIP_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/255615880605/generate-trip

# Região do cliente SQS.
# - Lambda: AWS_REGION é definido automaticamente pelo runtime (não precisa setar).
# - Local: se ~/.aws/config não tiver região default, use a mesma da fila:
AWS_DEFAULT_REGION=us-east-2

# -----------------------------------------------------------------------------
# S3 — perfil JSON + roteiros (após geração com sucesso ou erro)
# -----------------------------------------------------------------------------
# Nome do bucket. Se vazio, não grava no S3 (útil até o bucket existir).
S3_TRIP_PROFILE_BUCKET=
# Opcional: endpoint custom (ex.: LocalStack). Na AWS real deixe em branco.
# AWS_ENDPOINT_URL=

# Permissões IAM típicas na role/usuário: s3:PutObject, s3:GetObject, s3:ListBucket
# no ARN do bucket (ou prefixo arn:...:bucket/name/*).

# -----------------------------------------------------------------------------
# Credenciais AWS — só LOCAL ou CI (nunca commite valores reais)
# -----------------------------------------------------------------------------
# Na Lambda NÃO configure estas variáveis: a função usa o IAM role (execution role).
#
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Se usar credencial temporária (SSO, assume role, credenciais do console):
# AWS_SESSION_TOKEN=
# Perfil do arquivo ~/.aws/credentials (alternativa às chaves acima):
# AWS_PROFILE=

# -----------------------------------------------------------------------------
# Raiz das transcrições (subpastas com transcricao*.txt)
# -----------------------------------------------------------------------------
# Opcional. Se vazio, usa a raiz do projeto / pasta do pacote Lambda (BASE_DIR).
# Em Lambda com EFS ou layout custom, aponte para o mount:
# TRANSCRIPTS_ROOT=/mnt/transcripts

# -----------------------------------------------------------------------------
# Logging — local e Lambda
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_MAX_CHARS=15000

# -----------------------------------------------------------------------------
# Lambda (referência — definidos pelo AWS, não precisa colar no .env local)
# -----------------------------------------------------------------------------
# AWS_LAMBDA_FUNCTION_NAME
# AWS_REGION
# LAMBDA_TASK_ROOT

# -----------------------------------------------------------------------------
# Teste local
# -----------------------------------------------------------------------------
# Mesmo pipeline da Lambda, contra a fila real (credenciais ~/.aws ou env):
#   python scripts/poll_sqs_local.py
# Um lote e sai:
#   python scripts/poll_sqs_local.py --once
# Handler com JSON de exemplo (sem receber da fila):
#   python scripts/run_lambda_sample_event.py
